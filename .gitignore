```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Python package management
*.egg-info/
*.egg

# Virtual environments
venv/
.venv/
env/
.ENV/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Coverage reports
.coverage
coverage/
htmlcov/

# Pytest cache
.pytest_cache/

# Mypy cache
.mypy_cache/

# Build artifacts
dist/
build/
*.so
*.dylib
*.dll
*.exe
*.out

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```