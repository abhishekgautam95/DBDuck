# Logging
DBDUCK_LOG_LEVEL=INFO

# SQL runtime settings
DBDUCK_SQL_POOL_SIZE=5
DBDUCK_SQL_MAX_OVERFLOW=10
DBDUCK_SQL_POOL_TIMEOUT=30
DBDUCK_SQL_POOL_RECYCLE=1800
DBDUCK_SQL_POOL_PRE_PING=true
DBDUCK_SQL_ECHO=false

# Mongo runtime settings
DBDUCK_MONGO_CONNECT_TIMEOUT_MS=3000
DBDUCK_MONGO_MAX_POOL_SIZE=100
DBDUCK_MONGO_MIN_POOL_SIZE=0
DBDUCK_MONGO_RETRY_ATTEMPTS=3
DBDUCK_MONGO_RETRY_BACKOFF_MS=100

# Security hardening
DBDUCK_HASH_SENSITIVE_FIELDS=true
DBDUCK_BCRYPT_ROUNDS=12
DBDUCK_SECURITY_AUDIT_ENABLED=true
DBDUCK_SECURITY_AUDIT_ENTITY=security_logs
DBDUCK_RATE_LIMIT_ENABLED=false
DBDUCK_RATE_LIMIT_MAX_REQUESTS=60
DBDUCK_RATE_LIMIT_WINDOW_SECONDS=60

# Example app config
APP_DB_TYPE=sql
APP_DB_INSTANCE=sqlite
APP_DB_URL=sqlite:///dbduck_app.db
APP_LOG_LEVEL=INFO

# Alembic migration URL
DATABASE_URL=sqlite:///test.db

# Integration tests
RUN_MONGO_INTEGRATION=0
RUN_MONGO_TX_INTEGRATION=0
MONGO_TEST_URL=mongodb://localhost:27017/udom_test
RUN_MYSQL_INTEGRATION=0
MYSQL_TEST_URL=mysql+pymysql://root:password@localhost:3306/udom_test
RUN_POSTGRES_INTEGRATION=0
POSTGRES_TEST_URL=postgresql+psycopg2://postgres:password@localhost:5432/udom_test
RUN_MSSQL_INTEGRATION=0
MSSQL_TEST_URL=mssql+pyodbc://sa:Password!123@localhost:1433/udom_test?driver=ODBC+Driver+17+for+SQL+Server
